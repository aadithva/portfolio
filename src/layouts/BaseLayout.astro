---
import "@/styles/global.css";
import "@/styles/editorial-mono.css";
import GridBackdrop from "@/components/atoms/GridBackdrop.astro";
import Header from "@/components/organisms/Header.astro";
import Footer from "@/components/organisms/Footer.astro";
import AadithCompanion from "@/components/organisms/AadithCompanion.astro";
import { siteConfig } from "@/data/siteConfig";

interface Props {
  title?: string;
  description?: string;
  /** Render without the global header/footer (e.g. gated pages). */
  bare?: boolean;
  /** Override the route-aware portfolio companion visibility. */
  companion?: boolean;
}

const {
  title,
  description = siteConfig.description,
  bare = false,
  companion,
} = Astro.props;

const fullTitle = title ? `${title} — ${siteConfig.name}` : siteConfig.title;
const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).href;
const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isDetailRoute =
  /^\/work\/[^/]+/.test(pathname) || /^\/lab\/[^/]+/.test(pathname);
const showCompanion = !bare && (companion ?? !isDetailRoute);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://use.typekit.net/wje4mxt.css" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class:list={[showCompanion && "has-companion"]}>
    <a class="skip-link" href="#main" data-companion-background>Skip to content</a>
    <GridBackdrop />
    <div class="ambient-grain" aria-hidden="true"></div>
    {bare ? (
      <slot />
    ) : showCompanion ? (
      <div class="portfolio-shell portfolio-shell--companion">
        <div class="portfolio-shell__canvas" data-companion-background>
          <Header />
          <main id="main">
            <slot />
          </main>
          <Footer />
        </div>
        <AadithCompanion />
      </div>
    ) : (
      <>
        <Header />
        <main id="main">
          <slot />
        </main>
        <Footer />
      </>
    )}

    <script>
      // Scroll reveal + line draw via IntersectionObserver.
      const revealEls = document.querySelectorAll(".reveal, .line, .routemap");
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (!("IntersectionObserver" in window) || reduce) {
        revealEls.forEach((el) => el.classList.add("is-visible"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -6% 0px" }
        );
        revealEls.forEach((el) => io.observe(el));
      }

      // Route map: set the dash length to the path's real length.
      const routePath = document.querySelector(".route-path");
      if (routePath && routePath instanceof SVGPathElement) {
        const len = Math.ceil(routePath.getTotalLength());
        routePath.style.setProperty("--route-len", String(len));
      }

    </script>
  </body>
</html>
