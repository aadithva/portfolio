---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Reveal from "@/components/atoms/Reveal.astro";
import HoverRevealList from "@/components/molecules/HoverRevealList.astro";
import { projects } from "@/data/projects";
---
<BaseLayout title="Work" description="Six real working contexts across enterprise AI, founder work, fintech, early-stage products, Web3, and data design.">
  <div class="page container">
    <Reveal>
      <h1 class="page-header__title">Work</h1>
      <p class="page-header__intro">Six real working contexts, kept deliberately short: enterprise AI, founder work, fintech, early-stage products, Web3, and data design. Some stories are deeply documented; the thinner ones stay honest rather than borrowing impact they cannot prove.</p>
    </Reveal>

    <div class="spacer-md"></div>

    <HoverRevealList projects={projects} />
  </div>
</BaseLayout>
