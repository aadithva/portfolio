---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Reveal from "@/components/atoms/Reveal.astro";
import SectionLabel from "@/components/atoms/SectionLabel.astro";
import Line from "@/components/atoms/Line.astro";
import { siteConfig } from "@/data/siteConfig";

const elsewhere = [
  { label: "LinkedIn", href: siteConfig.social.linkedin },
  { label: "Behance", href: siteConfig.social.behance },
];
---
<BaseLayout title="Contact" description="Contact Aadith about AI product design, creative infrastructure, design engineering, Owly, or a thoughtful side quest.">
  <div class="page container">
    <Reveal>
      <h1 class="page-header__title">Say hello</h1>
      <p class="page-header__intro">Hiring for AI product design, building creative infrastructure, or trying to make a complicated system easier to trust? I’m listening.</p>
    </Reveal>

    <div class="spacer-xl"></div>
    <Line />
    <div class="spacer-xl"></div>

    <Reveal>
      <a class="contact-email" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
    </Reveal>

    <div style="height:clamp(2.5rem,4vw,4rem)"></div>

    <Reveal>
      <p class="muted-note">Hyderabad, India&nbsp;&nbsp;·&nbsp;&nbsp;IST (UTC +5:30)&nbsp;&nbsp;·&nbsp;&nbsp;Usually replies within a day</p>
    </Reveal>

    <div class="spacer-xl"></div>

    <Reveal class="prose">
      <p>The strongest fit is a team where design sits close to product behavior: enterprise AI, creative tooling, evaluation systems, or early-stage work that needs someone to research, prototype, explain, and stay through implementation.</p>
      <p>If you are looking at Owly from a founder or investment angle, I am equally happy to talk about the less cinematic parts: customer learning, the service-to-software bridge, and what still needs to become repeatable. Design questions, cycling stories, and good rabbit holes are welcome too.</p>
    </Reveal>

    <div class="spacer-xl"></div>
    <Line />
    <div style="height:3rem"></div>

    <Reveal>
      <SectionLabel>Elsewhere</SectionLabel>
      <div style="height:2rem"></div>
      <div class="elsewhere-list">
        {elsewhere.map((l) => (
          <a class="elsewhere-link" href={l.href} target="_blank" rel="noopener noreferrer">
            {l.label}<span class="elsewhere-link__arrow">→</span>
          </a>
        ))}
      </div>
    </Reveal>
  </div>
</BaseLayout>
