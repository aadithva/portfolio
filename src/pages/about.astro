---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Reveal from "@/components/atoms/Reveal.astro";
import SectionLabel from "@/components/atoms/SectionLabel.astro";
import Line from "@/components/atoms/Line.astro";
import {
  aboutApproaches,
  aboutBio,
  aboutLead,
  aboutMilestones,
  aboutStats,
} from "@/data/about";
---
<BaseLayout title="About" description="Product designer at Microsoft, co-founder of Owly, and endurance cyclist from Kerala.">
  <div class="page container">
    <Reveal>
      <h1 class="page-header__title">About</h1>
      <p class="page-header__intro">Designer, founder, builder, cyclist, and enthusiastic asker of small questions.</p>
    </Reveal>

    <div class="spacer-md"></div>

    <Reveal>
      <div class="stat-grid">
        {aboutStats.map((s) => (
          <div>
            <p class="stat__value">{s.value}</p>
            <p class="stat__label">{s.label}</p>
          </div>
        ))}
      </div>
    </Reveal>

    <div class="spacer-lg"></div>

    <div class="bio-grid">
      <Reveal>
        <blockquote class="bio-quote">
          &ldquo;I like the moment when a messy problem starts making a little more sense.&rdquo;
        </blockquote>
      </Reveal>
      <Reveal class="bio-body" delay={100}>
        {aboutBio.map((paragraph) => <p>{paragraph}</p>)}
      </Reveal>
    </div>

    <div class="spacer-lg"></div>

    <Reveal>
      <p class="prose-lead">
        {aboutLead}
      </p>
    </Reveal>

    <div class="spacer-lg"></div>

    <Reveal><SectionLabel>Timeline</SectionLabel></Reveal>
    <div style="height:2.5rem"></div>
    <div class="timeline">
      {aboutMilestones.map((m, i) => (
        <Reveal delay={i * 50}>
          <div class="timeline__item">
            <span class="timeline__bgyear" aria-hidden="true">{m.year}</span>
            <div class="timeline__row">
              <p class="timeline__year">{m.year}</p>
              <div>
                <h3 class="timeline__title">{m.title}</h3>
                <p class="timeline__desc">{m.description}</p>
              </div>
            </div>
          </div>
        </Reveal>
      ))}
      <div class="timeline__end"></div>
    </div>

    <div class="spacer-lg"></div>

    <Reveal><SectionLabel>How I work</SectionLabel></Reveal>
    <div style="height:2.5rem"></div>
    <Line />
    <div style="height:3rem"></div>
    <div class="approach-grid">
      {aboutApproaches.map((a, i) => (
        <Reveal delay={i * 80}>
          <h3 class="approach__title">{a.title}</h3>
          <p class="approach__body">{a.body}</p>
        </Reveal>
      ))}
    </div>
  </div>
</BaseLayout>
