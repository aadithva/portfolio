---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Reveal from "@/components/atoms/Reveal.astro";
import Line from "@/components/atoms/Line.astro";
import DottedIndiaMap from "@/components/molecules/DottedIndiaMap.astro";
import {
  adventureRoute,
  adventureStats,
  adventureStory,
} from "@/data/adventures";
---
<BaseLayout title="Adventures" description="Two India-scale cycling journeys, including a government-supported Kashmir-to-Kanyakumari ride in 2025.">
  <div class="page container">
    <Reveal>
      <h1 class="page-header__title">Adventures</h1>
      <p class="page-header__intro">Long rides, questionable decisions, and stories that improve slightly every time I tell them.</p>
    </Reveal>

    <div class="spacer-xl"></div>

    <section>
      <Reveal>
        <p class="adv-display">4,000 km</p>
        <p class="adv-sub">Kashmir to Kanyakumari. 16 days. One bicycle. Not enough sleep.</p>
      </Reveal>

      <div class="spacer-xl"></div>

      <Reveal class="prose" delay={50}>
        {adventureStory.map((paragraph) => <p>{paragraph}</p>)}
      </Reveal>

      <div class="spacer-xl"></div>
      <Line />
      <div style="height:3rem"></div>

      <div class="stat-grid">
        {adventureStats.map((s, i) => (
          <Reveal delay={i * 80}>
            <p class="stat__value">{s.value}</p>
            <p class="stat__label">{s.label}</p>
          </Reveal>
        ))}
      </div>
    </section>

    <div class="spacer-xl"></div>

    <section class="route-card">
      <div class="route-card__copy">
        <p class="section-label">Route, simplified</p>
        <h2 class="route-card__title">From Kashmir to the country’s southern tip.</h2>
        <p class="route-card__body">This is a geographic overview, not a turn-by-turn GPS trace. The line follows a simplified north-to-south corridor through mainland India.</p>
        <dl class="route-card__facts">
          <div>
            <dt>Start</dt>
            <dd>{adventureRoute.start}</dd>
          </div>
          <div>
            <dt>Finish</dt>
            <dd>{adventureRoute.finish}</dd>
          </div>
          <div>
            <dt>Distance</dt>
            <dd>{adventureRoute.distance}</dd>
          </div>
          <div>
            <dt>Time</dt>
            <dd>{adventureRoute.time}</dd>
          </div>
        </dl>
      </div>

      <div class="routemap">
        <DottedIndiaMap />
      </div>
    </section>
  </div>
</BaseLayout>
