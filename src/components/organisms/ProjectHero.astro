---
import type { Project } from "@/types";
import Reveal from "@/components/atoms/Reveal.astro";
import fs from "node:fs";
import path from "node:path";

interface Props {
  project: Project;
}
const { project } = Astro.props;

const meta = [
  { label: "Role", value: project.role },
  { label: "Year", value: project.year },
  { label: "Client", value: project.client },
  { label: "Category", value: project.category },
];

const PUBLIC_DIR = path.resolve(process.cwd(), "public");
const thumb = project.thumbnail;
const hasThumb =
  !!thumb && thumb.startsWith("/")
    ? (() => { try { return fs.statSync(path.join(PUBLIC_DIR, thumb)).isFile(); } catch { return false; } })()
    : false;
---
<section class="project-hero">
  <div class="container">
    <Reveal as="h1" class="project-hero__title">{project.title}</Reveal>
    <Reveal as="p" class="project-hero__description" delay={50}>
      {project.description}
    </Reveal>
    <Reveal class="project-hero__meta" delay={100}>
      {meta.map((m) => (
        <div>
          <p class="meta__label">{m.label}</p>
          <p class="meta__value">{m.value}</p>
        </div>
      ))}
    </Reveal>
    {project.confidentialityNote && (
      <Reveal class="project-hero__note" delay={140}>
        <p>{project.confidentialityNote}</p>
      </Reveal>
    )}
  </div>
  {hasThumb && (
    <div class="container">
      <Reveal>
        <figure class="case-figure aspect-16x9">
          <img src={thumb} alt={`${project.title} — cover`} loading="eager" decoding="async" />
        </figure>
      </Reveal>
    </div>
  )}
</section>
