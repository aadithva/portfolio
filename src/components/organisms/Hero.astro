---
import Reveal from "@/components/atoms/Reveal.astro";
---
<section class="hero container">
  <div class="hero__inner">
    <Reveal as="p" class="hero__label">
      Product design / AI systems / founder work
    </Reveal>

    <Reveal as="h1" class="hero__statement">
      I design AI products people can inspect, direct, and actually use.
    </Reveal>

    <Reveal class="hero__byline" delay={250}>
      <span class="hero__name">Aadith V A</span>
      <span class="hero__dash">—</span>
      <span class="hero__role">
        Product Designer at Microsoft&nbsp;&nbsp;·&nbsp;&nbsp;Co-founder, Owly
      </span>
    </Reveal>
  </div>
</section>
