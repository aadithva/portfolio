---
import { getFeaturedProjects } from "@/data/projects";
import HoverRevealList from "@/components/molecules/HoverRevealList.astro";
import SectionLabel from "@/components/atoms/SectionLabel.astro";
import Line from "@/components/atoms/Line.astro";
import Reveal from "@/components/atoms/Reveal.astro";

const featured = getFeaturedProjects();
---
<section class="container featured">
  <Line />
  <div class="spacer-sm"></div>

  <Reveal>
    <SectionLabel>A few things I’ve worked on</SectionLabel>
  </Reveal>
  <div style="height:2.5rem"></div>

  <HoverRevealList projects={featured} showViewAll />
</section>
