---
interface Props {
  enabled?: boolean;
  storageKey?: string;
}

const { enabled = false, storageKey = "copilot-unlocked" } = Astro.props;
const password = import.meta.env.PUBLIC_WORK_GATE_PASSWORD;
const active = enabled && typeof password === "string" && password.length > 0;
---
{active && (
  <div class="gate" data-gate>
    <div class="gate__inner">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin:0 auto;">
        <rect x="8" y="20" width="32" height="24" rx="2" stroke="currentColor" stroke-width="2" />
        <path d="M16 20V14C16 9.58172 19.5817 6 24 6C28.4183 6 32 9.58172 32 14V20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        <circle cx="24" cy="32" r="3" fill="currentColor" />
      </svg>
      <h1 class="gate__title">Protected project</h1>
      <p class="gate__sub">This case study is under NDA. Enter the password to view.</p>
      <form class="gate__form" data-gate-form>
        <input class="gate__input" type="password" placeholder="Enter password" autocomplete="off" data-gate-input />
        <p class="gate__error is-hidden" data-gate-error>Incorrect password. Please try again.</p>
        <button class="gate__button" type="submit">Unlock</button>
      </form>
    </div>
  </div>
)}

<div data-protected class:list={[active && "is-hidden"]}>
  <slot />
</div>

{active && (
  <script is:inline define:vars={{ storageKey, password }}>
    (() => {
      const gate = document.querySelector("[data-gate]");
      const content = document.querySelector("[data-protected]");
      const form = document.querySelector("[data-gate-form]");
      const input = document.querySelector("[data-gate-input]");
      const error = document.querySelector("[data-gate-error]");
      if (!gate || !content) return;

      const unlock = () => {
        gate.classList.add("is-hidden");
        content.classList.remove("is-hidden");
      };

      if (sessionStorage.getItem(storageKey) === "true") {
        unlock();
        return;
      }

      form?.addEventListener("submit", (event) => {
        event.preventDefault();
        if (input && input.value === password) {
          sessionStorage.setItem(storageKey, "true");
          unlock();
        } else {
          error?.classList.remove("is-hidden");
          if (input) input.value = "";
        }
      });

      input?.addEventListener("input", () => error?.classList.add("is-hidden"));
    })();
  </script>
)}
