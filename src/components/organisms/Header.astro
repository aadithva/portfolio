---
import { navLinks } from "@/data/navigation";
import { siteConfig } from "@/data/siteConfig";
import BrandLockup from "@/components/atoms/BrandLockup.astro";

const path = Astro.url.pathname;
const isActive = (href: string) =>
  path === href || path.startsWith(href + "/");
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__brand" aria-label={`${siteConfig.name}, home`}>
      <BrandLockup class="site-header__lockup" />
    </a>

    <nav class="nav" aria-label="Primary">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={["nav__link", { "is-active": isActive(link.href) }]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>
