---
import type { CaseStudySection } from "@/types";
import Reveal from "@/components/atoms/Reveal.astro";
import Line from "@/components/atoms/Line.astro";
import fs from "node:fs";
import path from "node:path";

interface Props {
  section: CaseStudySection;
}
const { section } = Astro.props;

// Resolve a `/images/...` URL to its filesystem path under /public so we can
// gracefully fall back to the placeholder block when the asset is missing.
const PUBLIC_DIR = path.resolve(process.cwd(), "public");
function imageExists(src: string): boolean {
  if (!src || !src.startsWith("/")) return false;
  try {
    return fs.statSync(path.join(PUBLIC_DIR, src)).isFile();
  } catch {
    return false;
  }
}

const liveImages: string[] = (section.images ?? []).filter(imageExists);
const hasLive = liveImages.length > 0;
---
{section.type === "text" && (
  <Reveal class="case-block container">
    <div class="case-text__inner">
      {section.heading && <h2 class="case-text__heading">{section.heading}</h2>}
      {section.content && <p class="case-text__body">{section.content}</p>}
    </div>
  </Reveal>
)}

{section.type === "image-full" && (
  <div class="case-block container">
    {hasLive
      ? liveImages.map((img) => (
          <Reveal>
            <figure class="case-figure aspect-16x9">
              <img src={img} alt={section.caption ?? section.heading ?? "Project image"} loading="lazy" decoding="async" />
            </figure>
          </Reveal>
        ))
      : (section.images ?? []).map(() => (
          <Reveal>
            <div class="placeholder-image aspect-16x9">{section.caption ?? section.heading ?? "Image"}</div>
          </Reveal>
        ))}
    {section.caption && (
      <Reveal class="case-caption"><p>{section.caption}</p></Reveal>
    )}
  </div>
)}

{section.type === "image-grid" && (
  <div class="case-block container">
    <div class:list={["image-grid", section.columns === 3 ? "image-grid--3" : "image-grid--2"]}>
      {hasLive
        ? liveImages.map((img, i) => (
            <Reveal delay={i * 90}>
              <figure class="case-figure aspect-4x3">
                <img src={img} alt={section.caption ?? `Project image ${i + 1}`} loading="lazy" decoding="async" />
              </figure>
            </Reveal>
          ))
        : (section.images ?? []).map((_, i) => (
            <Reveal delay={i * 90}>
              <div class="placeholder-image aspect-4x3">{section.caption ?? "Image"}</div>
            </Reveal>
          ))}
    </div>
    {section.caption && (
      <Reveal class="case-caption"><p>{section.caption}</p></Reveal>
    )}
  </div>
)}

{section.type === "stats" && (
  <div class="case-block container">
    <Line />
    <div style="height:3.5rem"></div>
    <div class="case-stats__grid">
      {(section.stats ?? []).map((stat, i) => (
        <Reveal delay={i * 80}>
          <p class="case-stat__value">{stat.value}</p>
          <p class="case-stat__label">{stat.label}</p>
        </Reveal>
      ))}
    </div>
  </div>
)}

{section.type === "quote" && (
  <div class="case-block container">
    <Reveal>
      <blockquote class="case-quote">
        <p>&ldquo;{section.quote}&rdquo;</p>
        {section.attribution && <cite>— {section.attribution}</cite>}
      </blockquote>
    </Reveal>
  </div>
)}

{section.type === "framework" && (
  <section class="case-block container">
    <Reveal>
      <div class="case-framework">
        <div class="case-framework__intro">
          <div>
            {section.label && <p class="case-framework__label">{section.label}</p>}
            {section.heading && <h2 class="case-framework__heading">{section.heading}</h2>}
          </div>
          {section.content && <p class="case-framework__body">{section.content}</p>}
        </div>
        <ol class="case-framework__items">
          {(section.items ?? []).map((item, i) => (
            <li>
              <span class="case-framework__index">{String(i + 1).padStart(2, "0")}</span>
              <h3>{item.title}</h3>
              <p>{item.content}</p>
            </li>
          ))}
        </ol>
      </div>
    </Reveal>
  </section>
)}
